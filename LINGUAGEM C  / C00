#include <stdio.h>

int main()
{
    char nome[50];
    int idade;
    float altura;
    
    printf("digite o nome: ");
    scanf("%s%" , &nome);
    
    printf("digite o idade: ");
    scanf("%d%" , &idade);
    
    printf("digite sua altura: ");
    scanf("%f%" , &altura);
    
    printf("seu nome é: %s\n" , nome);
    printf("sua idade: %d\n" , idade);
    printf("sua altura é: %f\n" , altura);
   
    return 0;

}


