#include <stdio.h>

int main()
{
    int n1, option = 0;
    char r;
    
    
    while (option != 3) {
        printf("1. Dobro\n");
        printf("2. Quadrado\n");
        printf("3. Sair\n");
        
        printf("Digite sua opção: ");
        scanf("%d", &option);
        
        if(option == 1) {
            printf("Digite seu numero: ");
            scanf("%d", &n1);
            r = n1 * 2;
            printf("O dobro do seu numero é: %d\n", r);
        
            
        }else if(option == 2) {
            printf("Digite seu numero: ");
            scanf("%d", &n1);
            r = n1 * n1;
            printf("O quadrado é: %d\n", r);
        
            
        }else if (option == 3) {
            printf("Saindo..\n");
        
            
        }else {
            printf("Opcao invalida\n");
            break;        
        }
        
    }

    return 0;
}
